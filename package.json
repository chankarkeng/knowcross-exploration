{
  "name": "knowcross-unifocus-wrapper",
  "version": "0.1.0",
  "private": true,
  "description": "Thin Express+TS proxy in front of the Unifocus Integration API. Handles HMAC signing and per-call logging so internal callers see a clean interface.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/swagger-ui-express": "^4.1.6",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.0"
  }
}
